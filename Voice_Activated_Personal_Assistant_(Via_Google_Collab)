audio_output = widgets.Output()

def speak(text, print_text=True):

    if print_text:
        print(f"Assistant: {text}")

    tts = gTTS(text=text, lang='en')

    filename = "response.mp3"
    tts.save(filename)

    with audio_output:
        audio_output.clear_output(wait=True)
        display(Audio(filename, autoplay=True))

